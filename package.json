{
  "name": "kit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "description": "Codex fullstack agent template",
  "scripts": {
    "dev:be": "pnpm --filter ./backend dev",
    "dev:fe": "pnpm --filter frontend dev",
    "build:be": "pnpm --filter ./backend build",
    "build:fe": "pnpm --filter frontend build",
    "check": "pnpm harness:check && pnpm typecheck:contracts && pnpm --filter ./backend typecheck && pnpm --filter frontend build && pnpm --filter frontend test --run && pnpm lint",
    "check:ci": "pnpm check && pnpm --filter ./backend test --run",
    "harness:check": "node tools/harness-doctor.mjs",
    "lint": "pnpm -r --no-bail lint",
    "prepare": "simple-git-hooks",
    "test": "pnpm --filter ./backend test",
    "typecheck:contracts": "pnpm --filter @kit/api-contracts typecheck",
    "typecheck": "pnpm typecheck:contracts && pnpm --filter ./backend typecheck && pnpm --filter frontend build"
  },
  "devDependencies": {
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm harness:check"
  }
}
